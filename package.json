{
  "name": "@mini-snipped-vault/monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "dev": "concurrently \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "start:frontend": "npm run start -w frontend",
    "start:backend": "npm run start -w backend",
    "build:shared": "npm run build -w shared",
    "build:backend": "npm run build:shared",
    "build:frontend": "npm run build:shared && npm run build -w frontend",

    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"

  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
